#!/bin/bash
set -x
exec > /var/mobile/vcamjoy_install.log 2>&1

echo "=== VCamJoy postinst START ==="
echo "Date: $(date)"
echo "Listing /var/jb/Applications:"
ls /var/jb/Applications/ 2>/dev/null || echo "NOT FOUND"

echo "Find VCamJoy.app:"
find / -name "VCamJoy.app" -maxdepth 8 2>/dev/null

echo "Running uicache..."
if [ -x /var/jb/usr/bin/uicache ]; then
    /var/jb/usr/bin/uicache -a && echo "uicache OK"
elif [ -x /usr/bin/uicache ]; then
    uicache -a && echo "uicache OK"
else
    echo "uicache NOT FOUND"
fi

echo "=== VCamJoy postinst END ==="
