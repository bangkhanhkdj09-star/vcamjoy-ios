#!/bin/bash
set -x
exec > /var/mobile/vcamjoy_install.log 2>&1

echo "=== VCamJoy postinst START ==="
echo "Date: $(date)"

# Tìm app thật sự
echo "=== find VCamJoy.app ==="
find /var/jb /private/var/jb 2>/dev/null -name "VCamJoy.app" -maxdepth 5

# uicache - thử nhiều path
echo "=== uicache ==="
if [ -x /var/jb/usr/bin/uicache ]; then
    echo "using /var/jb/usr/bin/uicache"
    /var/jb/usr/bin/uicache -a
elif [ -x /usr/bin/uicache ]; then
    echo "using /usr/bin/uicache"
    uicache -a
else
    echo "uicache not found, trying which:"
    which uicache || true
fi

echo "=== VCamJoy postinst END ==="
